<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - QueuePro</title>
    <link rel="stylesheet" href="/css/auth-styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="auth-page">
    <!-- Navigation -->
    <nav class="auth-navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                <%- include('../partials/logo') %>
            </a>
            <div class="nav-links">
                <a href="/login" class="btn-link">Login</a>
                <a href="/admin-login" class="btn-link admin-link">Admin Login</a>
            </div>
        </div>
    </nav>

    <!-- Register Container -->
    <div class="auth-container register-container">
        <!-- Register Card -->
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h1>Create Account</h1>
                <p>Join QueuePro today</p>
                <p
                    style="font-size: 12px; color: var(--text-secondary); margin-top: 8px; line-height: 1.3; border-left: 3px solid var(--primary-color); padding-left: 8px;">
                    <strong>Note:</strong> Registration is only for queue scheduling. No official documents are
                    submitted through this system.
                </p>
            </div>

            <form id="registerForm" class="auth-form">
                <!-- Full Name -->
                <div class="form-group">
                    <label for="fullName">
                        <i class="fas fa-id-card"></i>
                        Full Name
                    </label>
                    <input type="text" id="fullName" name="fullName" placeholder="Enter your full name" required>
                    <span class="error-message" id="fullNameError"></span>
                </div>

                <!-- Mobile Number -->
                <div class="form-group">
                    <label for="phone">
                        <i class="fas fa-mobile-alt"></i>
                        Mobile Number
                    </label>
                    <input type="tel" id="phone" name="phone" placeholder="Enter 10-digit mobile number" required
                        pattern="[0-9]{10}" autocomplete="tel">
                    <span class="error-message" id="phoneError"></span>
                </div>

                <!-- Email -->
                <div class="form-group">
                    <label for="email">
                        <i class="fas fa-envelope"></i>
                        Email Address
                    </label>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required
                        autocomplete="email">
                    <span class="error-message" id="emailError"></span>
                </div>

                <!-- Username -->
                <div class="form-group">
                    <label for="username">
                        <i class="fas fa-user"></i>
                        Username
                    </label>
                    <input type="text" id="username" name="username" placeholder="Choose a username" required
                        autocomplete="username">
                    <span class="error-message" id="usernameError"></span>
                </div>

                <!-- Role Selection -->
                <div class="form-group">
                    <label>
                        <i class="fas fa-briefcase"></i>
                        Select Your Role
                    </label>
                    <div class="role-selection">
                        <label class="role-option">
                            <input type="radio" name="role" value="citizen" required checked>
                            <span class="role-label">
                                <i class="fas fa-user-circle"></i>
                                <strong>Citizen</strong>
                                <p>Apply for documents & services</p>
                            </span>
                        </label>
                        <label class="role-option">
                            <input type="radio" name="role" value="officer" required>
                            <span class="role-label">
                                <i class="fas fa-user-tie"></i>
                                <strong>Officer</strong>
                                <p>Manage applications & queue</p>
                            </span>
                        </label>
                    </div>
                    <span class="error-message" id="roleError"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock"></i>
                        Password
                    </label>
                    <div class="password-input">
                        <input type="password" id="password" name="password" placeholder="Min 6 characters" required
                            autocomplete="new-password">
                        <button type="button" class="toggle-password" id="togglePassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="error-message" id="passwordError"></span>
                    <div class="password-strength" id="passwordStrength"></div>
                </div>

                <!-- Confirm Password -->
                <div class="form-group">
                    <label for="confirmPassword">
                        <i class="fas fa-lock"></i>
                        Confirm Password
                    </label>
                    <div class="password-input">
                        <input type="password" id="confirmPassword" name="confirmPassword"
                            placeholder="Confirm your password" required autocomplete="new-password">
                        <button type="button" class="toggle-password" id="toggleConfirmPassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="error-message" id="confirmPasswordError"></span>
                </div>

                <!-- Terms & Conditions -->
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="terms" name="terms" required>
                        <span>I agree to the <a href="#" target="_blank">Terms & Conditions</a></span>
                    </label>
                    <span class="error-message" id="termsError"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary btn-block" id="registerBtn">
                    <i class="fas fa-user-plus"></i>
                    Create Account
                </button>

                <!-- OAuth Divider -->
                <div class="oauth-divider">
                    <span>OR</span>
                </div>

                <!-- OAuth Buttons -->
                <div class="oauth-buttons-container">
                    <!-- Google Sign Up -->
                    <button type="button" class="btn btn-oauth btn-google" id="googleSignUpBtn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M23.745 12.27c0-.79-.07-1.54-.19-2.27h-11.3v4.28h6.47c-.29 1.48-1.14 2.73-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.59z"
                                fill="#4285F4" />
                            <path
                                d="M12.255 23.5c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.13-4.07 1.13-3.13 0-5.78-2.11-6.73-4.96h-3.98v3.09C3.395 20.43 7.795 23.5 12.255 23.5z"
                                fill="#34A853" />
                            <path
                                d="M5.525 14.76c-.47-1.45-.73-2.98-.73-4.57s.26-3.12.73-4.57V2.53h-3.98C1.925 4.92 1.255 8.45 1.255 12.19c0 3.74.67 7.27 1.73 10.66l3.98-3.09z"
                                fill="#FBBC05" />
                            <path
                                d="M12.255 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42C18.205 1.48 15.495 0 12.255 0c-4.46 0-8.86 3.07-10.245 7.52l3.98 3.09c.95-2.85 3.6-4.86 6.515-4.86z"
                                fill="#EA4335" />
                        </svg>
                        <span>Sign up with Google</span>
                </div>

                <!-- Login Link -->
                <div class="form-footer">
                    <p>Already have an account? <a href="/login">Login here</a></p>
                </div>
            </form>
        </div>

        <!-- Info Panel -->
        <div class="auth-info register-info">
            <h2>Why Join QueuePro?</h2>
            <div class="info-list">
                <div class="info-item">
                    <i class="fas fa-check-circle"></i>
                    <h4>Easy Queue Management</h4>
                    <p>Never wait unnecessarily - manage your queue in real-time</p>
                </div>
                <div class="info-item">
                    <i class="fas fa-lock"></i>
                    <h4>Secure & Private</h4>
                    <p>Your data is encrypted and protected at all times</p>
                </div>
                <div class="info-item">
                    <i class="fas fa-mobile-alt"></i>
                    <h4>Access Anywhere</h4>
                    <p>Use on desktop, tablet, or mobile devices</p>
                </div>
                <div class="info-item">
                    <i class="fas fa-headset"></i>
                    <h4>24/7 Support</h4>
                    <p>Our support team is always available to help</p>
                </div>
            </div>

            <div class="info-note">
                <i class="fas fa-lightbulb"></i>
                <p><strong>Tip:</strong> Choose your role wisely as it determines your dashboard features</p>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast"></div>

    <!-- Scripts -->
    <script src="/js/auth-system.js"></script>
    <script src="/js/ui-utils.js"></script>
    <script src="/js/register-handler.js"></script>
    <%- include('../partials/scroll-to-top') %>
</body>

</html>