<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - QueuePro</title>
    <link rel="stylesheet" href="/css/auth-styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="auth-page">
    <!-- Navigation -->
    <nav class="auth-navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                <i class="fas fa-stream"></i>
                <span>QueuePro</span>
            </a>
            <div class="nav-links">
                <a href="/register" class="btn-link">Register</a>
                <a href="/admin-login" class="btn-link admin-link">Admin Login</a>
            </div>
        </div>
    </nav>

    <!-- Login Container -->
    <div class="auth-container">
        <!-- Login Card -->
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-icon">
                    <i class="fas fa-sign-in-alt"></i>
                </div>
                <h1>Welcome Back</h1>
                <p>Login to your QueuePro account</p>
            </div>

            <form id="loginForm" class="auth-form">
                <!-- Username -->
                <div class="form-group">
                    <label for="username">
                        <i class="fas fa-user"></i>
                        Username or Mobile Number
                    </label>
                    <input type="text" id="username" name="username"
                        placeholder="Enter username or 10-digit mobile number" required autocomplete="username">
                    <span class="error-message" id="usernameError"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock"></i>
                        Password
                    </label>
                    <div class="password-input">
                        <input type="password" id="password" name="password" placeholder="Enter your password" required
                            autocomplete="current-password">
                        <button type="button" class="toggle-password" id="togglePassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="error-message" id="passwordError"></span>
                </div>

                <!-- Remember Me -->
                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" id="rememberMe" name="rememberMe">
                        <span>Remember me</span>
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary btn-block" id="loginBtn">
                    <i class="fas fa-sign-in-alt"></i>
                    Login
                </button>

                <!-- Register Link -->
                <div class="form-footer">
                    <p>Don't have an account? <a href="/register">Register here</a></p>
                </div>
            </form>
        </div>

        <section class="hero-section">
            <div class="hero-content">

                <div class="hero-brand">
                    QueuePro
                </div>

                <h1>Welcome Back.</h1>
                <h2>Let's Login.</h2>

                <p>
                    Access your digital tokens, track real-time queue positions,
                    and receive notifications when it's your turn to be served.
                </p>

                <ul class="hero-features">
                    <li>✔ Real-time Queue Tracking</li>
                    <li>✔ Digital Tokens</li>
                    <li>✔ Instant Notifications</li>
                </ul>

            </div>
        </section>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast"></div>

    <!-- Scripts -->
    <script src="/js/auth-system.js"></script>
    <script src="/js/ui-utils.js"></script>
    <script src="/js/login-handler.js"></script>
    <%- include('../partials/scroll-to-top') %>
</body>

</html>