    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-content">
                <div class="hero-text">

                    <h1>Eliminate Wait Time<br><span class="gradient-text">Frustration Forever</span></h1>
                    <p class="hero-description">
                        QueuePro is an academic prototype of a queue management system inspired by real-world government
                        service
                        centers such as Aadhaar, certificate verification, and municipal offices.
                        It demonstrates how token-based workflows and role-based dashboards can be used to manage public
                        service queues digitally.
                    </p>
                    <p style="font-size: 11px; opacity: 0.7; margin-top: 0.5rem;">
                        This system is developed for academic demonstration purposes and is not officially integrated
                        with any government department.
                    </p>
                    <div class="hero-buttons">
                        <button class="btn-large btn-primary" onclick="goToToken()">Get Your Token</button>
                        <button class="btn-large btn-outline" onclick="scrollToSection('services')">View
                            Services</button>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="floating-card card-1">
                        <div class="card-icon blue">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h4>Token Generated</h4>
                            <p id="card1-token">A001 - Aadhaar Update</p>
                            <span class="status-badge waiting">Next in Queue</span>
                        </div>
                    </div>
                    <div class="floating-card card-2">
                        <div class="card-icon green">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h4>Real-time Updates</h4>
                            <p id="card2-wait">Estimated wait: 8 minutes</p>
                            <div class="progress-bar">
                                <div class="progress-fill" id="card2-progress" style="width: 65%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="floating-card card-3">
                        <div class="card-icon orange">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
