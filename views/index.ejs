    <!-- Toast Notification -->
    <div id="toast" class="toast"></div>

    <!-- Scripts -->
    <script src="/js/auth-system.js"></script>
    <script src="/js/ui-utils.js"></script>
    <script src="/js/mobile-menu.js"></script>
    <script>
        // Smooth scroll
        function scrollToSection(sectionId) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // Get service token (index page)
        function getServiceToken(service) {
            window.location.href = '/login';
        }

        // Update waiting numbers periodically
        function updateWaitingNumbers() {
            if (document.getElementById('aadhaar-waiting')) document.getElementById('aadhaar-waiting').textContent = Math.floor(Math.random() * 10) + 1 + ' waiting';
            if (document.getElementById('caste-waiting')) document.getElementById('caste-waiting').textContent = Math.floor(Math.random() * 8) + 1 + ' waiting';
            if (document.getElementById('income-waiting')) document.getElementById('income-waiting').textContent = Math.floor(Math.random() * 12) + 1 + ' waiting';
            if (document.getElementById('birth-waiting')) document.getElementById('birth-waiting').textContent = Math.floor(Math.random() * 5) + 1 + ' waiting';

            // Update progress bar
            const progress = Math.floor(Math.random() * 40) + 30;
            document.getElementById('card2-progress').style.width = progress + '%';
            document.getElementById('card2-wait').textContent = 'Estimated wait: ' + progress + ' minutes';
        }

        // Update every 10 seconds
        setInterval(updateWaitingNumbers, 10000);
        updateWaitingNumbers(); // Initial call

        // Active nav link on scroll
        window.addEventListener('scroll', function () {
            const sections = document.querySelectorAll('section');
            const navLinks = document.querySelectorAll('.nav-link');

            let currentSection = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (pageYOffset >= sectionTop - 200) {
                    currentSection = section.getAttribute('id');
                }
            });

            navLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href').slice(1) === currentSection) {
                    link.classList.add('active');
                }
            });
        });

        // Service card click handler
        document.querySelectorAll('.service-card').forEach(card => {
            card.addEventListener('click', function () {
                const service = this.getAttribute('data-service');
                getServiceToken(service);
            });
        });
        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const navLinks = document.getElementById('navLinks');
        const navActions = document.querySelector('.nav-actions');

        if (mobileMenuBtn && navLinks) {
            mobileMenuBtn.addEventListener('click', () => {
                navLinks.classList.toggle('active');
                if (navActions) navActions.classList.toggle('active');
                mobileMenuBtn.classList.toggle('active');

                // Toggle body scroll when menu is open
                if (navLinks.classList.contains('active')) {
                    document.body.style.overflow = 'hidden';
                } else {
                    document.body.style.overflow = '';
                }
            });

            // Close menu when clicking on a link or button
            navLinks.querySelectorAll('a, button').forEach(link => {
                link.addEventListener('click', () => {
                    navLinks.classList.remove('active');
                    if (navActions) navActions.classList.remove('active');
                    mobileMenuBtn.classList.remove('active');
                    document.body.style.overflow = '';
                });
            });
        }
    </script>
    <a href="/login" class="floating-cta">Get Token</a>
    <%- include('partials/scroll-to-top') %>
</body>

</html>